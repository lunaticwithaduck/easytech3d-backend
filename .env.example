# PostgreSQL connection. Local default matches docker-compose.yml (port 5433).
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/easytech3d?schema=public

# Runtime
NODE_ENV=development
PORT=4000

# CORS — comma-separated allowed origins. The storefront dev server runs on :3000.
# Left blank in development = all origins allowed (see main.ts).
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# Seed sources (Phase 0). The Shopify admin CSV exports live in the FE repo (gitignored there),
# and collection membership is pulled from the still-live Shopify storefront.
SEED_CSV_DIR=/home/slova/easytech3d/easytech3d csv's
SEED_STORE_URL=https://www.easytech3d.com

ADMIN_TOKEN=dev-admin-token
